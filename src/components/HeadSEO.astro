---
import "@/styles/global.css";
import "@/styles/fonts.css";

interface Props {
  title?: string | undefined;
  description?: string | undefined;
  ogImage?: URL | undefined;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

if (Astro.props.ogImage === undefined) {
  Astro.props.ogImage = new URL("og-image.jpg", canonicalURL);
}

const finalOgImage =
  Astro.props.ogImage instanceof URL
    ? Astro.props.ogImage
    : new URL("og-image.jpg", canonicalURL);

const { title, description } = Astro.props; // Destructure only needed props here
---

<meta charset="utf-8" />
<meta name="robots" content="index, follow" />
<meta name="googlebot" content="index, follow" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<meta name="theme-color" content="#0284c7" />
<link rel="canonical" href={canonicalURL} />
<link rel="preconnect" href="https://fast.wistia.com" />
<link rel="preconnect" href="https://fast.wistia.net" crossorigin />
<link rel="dns-prefetch" href="https://fast.wistia.com" />
<!-- Favicon links generated by RealFaviconGenerator -->
<link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="shortcut icon" href="/favicon.ico" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<meta name="apple-mobile-web-app-title" content="Lethbridge Drone" />
<link rel="manifest" href="/site.webmanifest" />
<title>{title} | Lethbridge Drone</title>
<meta name="title" content={`${title} | Lethbridge Drone`} />
<meta name="description" content={description} />

<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={`${title} | Lethbridge Drone`} />
<meta property="og:description" content={description} />
<meta property="og:image" content={finalOgImage.toString()} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:type" content="image/jpeg" />

<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={`${title} | Lethbridge Drone`} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={finalOgImage.toString()} /> {/* Use finalOgImage */}
